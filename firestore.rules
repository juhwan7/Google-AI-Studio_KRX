rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: snapshots
    // Fields:
    //   - timestamp: number (required)
    //   - kospi: object (required)
    //   - kosdaq: object (required)
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "kjh71047@gmail.com" && request.auth.token.email_verified == true));
    }

    match /snapshots/{snapshotId} {
      allow read: if true; // Publicly readable for the dashboard
      allow write: if isAdmin(); // Only admin (server-side with admin SDK or specific user) can write
    }

    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;
    }
  }
}
